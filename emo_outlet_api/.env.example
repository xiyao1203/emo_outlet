# 情绪出口 API - 环境配置

# === 应用 ===
DEBUG=True
HOST=0.0.0.0
PORT=8000

# === 数据库（留空则使用 SQLite 开发模式）===
# DATABASE_URL=mysql+aiomysql://root:password@localhost:3306/emo_outlet?charset=utf8mb4
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_NAME=emo_outlet

# === Redis ===
# REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# === JWT ===
SECRET_KEY=change-this-to-a-random-secret-key-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# === LLM 配置（至少配置一个）===
# provider: openai / deepseek / qwen / mock
LLM_PROVIDER=mock
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
QWEN_API_KEY=

# === OSS ===
OSS_ENABLED=False
OSS_ACCESS_KEY=
OSS_SECRET_KEY=
OSS_BUCKET=
OSS_ENDPOINT=

# === 安全 ===
MAX_DAILY_FREE_SESSIONS=3
SENSITIVE_WORD_FILE=
