# ============================================================
# 情绪出口（Emo Outlet）环境配置
# ============================================================
# 复制此文件为 .env 然后配置你的环境变量
# cp .env.example .env

# ============================================================
# 应用配置
# ============================================================
APP_NAME=情绪出口 API
APP_VERSION=1.0.0
DEBUG=true
HOST=0.0.0.0
PORT=8000

# ============================================================
# 数据库配置
# ============================================================
# 开发环境使用 SQLite（无需额外配置）
# DATABASE_URL=sqlite+aiosqlite:///./emo_outlet.db

# 生产环境使用 MySQL
# DATABASE_URL=mysql+asyncmy://user:password@localhost:3306/emo_outlet

# ============================================================
# Redis 配置（可选，用于会话缓存和速率限制）
# ============================================================
# REDIS_URL=redis://localhost:6379/0

# ============================================================
# JWT 配置
# ============================================================
SECRET_KEY=your-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ============================================================
# LLM API 配置（至少配置一个）
# ============================================================
# LLM_PROVIDER 可选值: mock, openai, deepseek, qwen
# mock=使用本地模拟回复（无需 API Key）
LLM_PROVIDER=mock

# OpenAI
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx
# OPENAI_MODEL=gpt-4o-mini

# DeepSeek
# LLM_PROVIDER=deepseek
# DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxx
# DEEPSEEK_MODEL=deepseek-chat

# 通义千问
# LLM_PROVIDER=qwen
# QWEN_API_KEY=sk-xxxxxxxxxxxxxxxx
# QWEN_MODEL=qwen-plus

# ============================================================
# 图像生成 API 配置
# ============================================================
# IMAGE_PROVIDER 可选值: mock, dalle, stable_diffusion
IMAGE_PROVIDER=mock
# DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxx

# ============================================================
# 对象存储配置（OSS，用于海报/头像存储）
# ============================================================
# OSS_ENABLED=false
# OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
# OSS_BUCKET=emo-outlet
# OSS_ACCESS_KEY_ID=your-access-key
# OSS_ACCESS_KEY_SECRET=your-secret-key
