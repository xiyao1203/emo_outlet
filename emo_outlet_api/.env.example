# Emo Outlet API environment example

APP_NAME=情绪释放 API
APP_VERSION=1.0.0
DEBUG=true
HOST=0.0.0.0
PORT=8686

# Development can use SQLite directly.
DATABASE_URL=sqlite+aiosqlite:///./emo_outlet.db

SECRET_KEY=your-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# LLM provider
# mock / openai / deepseek / qwen
LLM_PROVIDER=openai
OPENAI_API_KEY=tp-your-compatible-key
OPENAI_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1
LLM_MODEL=mimo-v2.5-pro

# Image generation
# auto / openai / pollinations
IMAGE_PROVIDER=auto
IMAGE_MODEL=dall-e-3
IMAGE_SIZE=1024x1024
IMAGE_QUALITY=high
IMAGE_STYLE=vivid

# Speech
# auto / openai / disabled
ASR_PROVIDER=mock
TTS_PROVIDER=auto
TTS_MODEL=gpt-4o-mini-tts
TTS_VOICE=alloy
TTS_FORMAT=mp3

OSS_ENABLED=false

MAX_MESSAGE_LENGTH=5000
MAX_SESSION_DURATION_MINUTES=10
SENSITIVE_WORD_FILE=

COMPLIANCE_VERSION=1.0.0
MAX_DAILY_SESSIONS_UNDER_14=1
MAX_DAILY_SESSIONS_14_TO_18=2
MAX_DAILY_SESSIONS_ADULT=3
MAX_DAILY_SESSIONS_VISITOR=1
MAX_CONVERSATION_TURNS=50
MAX_CONVERSATION_TURNS_UNDER_14=10
MAX_CONVERSATION_TURNS_14_TO_18=25
ENABLE_AUDIT_LOG=true
